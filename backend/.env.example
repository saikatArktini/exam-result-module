PORT=5000
NODE_ENV=development

# MongoDB Connection String (Replace with your own)
# Example: mongodb+srv://username:password@cluster.mongodb.net/exam_result_db?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/exam_result_db"

# JWT Authentication Settings
JWT_SECRET=your_super_secret_jwt_key_123
JWT_EXPIRE=1h
